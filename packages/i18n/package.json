{
  "name": "@loyaltydog/i18n",
  "version": "1.0.0",
  "description": "Shared localization package for LoyaltyDog platform using i18next and Lokalise",
  "main": "dist/node/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    "./react": "./dist/react/index.js",
    "./node": "./dist/node/index.js",
    "./rtl": "./dist/rtl/index.js",
    "./locales/*": "./locales/*"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lokalise:download": "lokalise2 --config .lokalise.json download",
    "lokalise:upload": "lokalise2 --config .lokalise.json upload",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "i18n",
    "localization",
    "translation",
    "loyaltydog",
    "i18next"
  ],
  "author": "LoyaltyDog",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@lokalise/cli": "^7.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.50.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "i18next": "^23.7.0",
    "i18next-browser-language-detector": "^7.2.0",
    "i18next-http-backend": "^2.4.0",
    "react-i18next": "^14.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "files": [
    "dist",
    "locales",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
