{
    "compilerOptions": {
        "allowSyntheticDefaultImports": "1",
        "declaration": "1",
        "declarationMap": "1",
        "esModuleInterop": "1",
        "forceConsistentCasingInFileNames": "1",
        "lib": [
            "ES2020"
        ],
        "module": "commonjs",
        "moduleResolution": "nó",
        "outDir": ".\/dist",
        "resolveJsonModule": "1",
        "rootDir": ".\/src",
        "skipLibCheck": "1",
        "sourceMap": "1",
        "strict": "1",
        "target": "ES2020"
    },
    "exclude": [
        "módulos_nó",
        "dist",
        "**\/*.test.ts",
        "**\/*.test.tsx"
    ],
    "include": [
        "src\/**\/*"
    ]
}